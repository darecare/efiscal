PROJECT_NAME=Kliklak Dashboard
DATABASE_URL=postgresql://kliklak:kliklak@db:5432/kliklak_dashboard
# Generate a secure secret key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment (dev, qa, prod) - determines which product_statuses_<env>.json to load
ENVIRONMENT=dev

# MerchantPro API Configuration
# Use your shop domain base URL (backend appends /api/v2/...)
MERCHANTPRO_API_URL=https://probaproba.shopmania.biz
MERCHANTPRO_API_USERNAME=your-merchantpro-username
MERCHANTPRO_API_PASSWORD=your-merchantpro-password
